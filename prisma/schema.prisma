// NEXUS Schedule Intelligence — Phase 1.1 schema
// Future phases will add Tenant, Membership, Schedule, ScheduleVersion, AuditEvent.
//
// Connection strings:
//   POSTGRES_PRISMA_URL          — pooled, for Vercel runtime (uses pgbouncer)
//   POSTGRES_URL_NON_POOLING     — direct, for migrations only
// Both are auto-injected by Vercel Postgres / Neon Vercel integration.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ── Phase 1.1 — minimal user model ──────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}
