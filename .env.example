# NEXUS environment variables
# Copy this to .env.local for local dev. In production these are set in Vercel Dashboard.

# ─── Phase 1.1: Database (Vercel Postgres / Neon) ──────────────────────────
# Auto-injected by Vercel when you create a Postgres database under
# Project → Storage → Create → Postgres. Both URLs point to the same DB.
#
# POSTGRES_PRISMA_URL is pooled (pgbouncer) — used at runtime by the app.
# POSTGRES_URL_NON_POOLING is direct — used by `prisma migrate` / `prisma db push`.
POSTGRES_PRISMA_URL=postgres://user:pass@host/db?pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgres://user:pass@host/db

# Token to gate the one-shot /api/admin/migrate endpoint that applies
# prisma/migrations/*/migration.sql to the live DB. Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# or just paste any 64+ char random string. Set it in Vercel → Settings → Env Vars.
BOOTSTRAP_TOKEN=replace-with-long-random-string

# ─── Phase 1.2: Auth (NextAuth + Resend magic-link email) ──────────────────
# Generate NEXTAUTH_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or paste any 64+ char random string. Vercel → Settings → Env Vars.
NEXTAUTH_SECRET=replace-with-long-random-string

# Production canonical URL (must match the domain users sign in from).
# Use the Vercel custom domain once attached; until then, the production deployment URL.
NEXTAUTH_URL=https://your-prod-host.vercel.app

# Resend API key (free tier 3k emails/month at resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender email (must be on a domain verified in Resend, OR use the
# "onboarding@resend.dev" sandbox sender for early testing).
EMAIL_FROM=NEXUS <onboarding@resend.dev>

# ─── Phase 2 (later): AI ────────────────────────────────────────────────────
# GOOGLE_GENERATIVE_AI_API_KEY=
# ANTHROPIC_API_KEY=
